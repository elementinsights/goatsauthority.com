---
import { getCollection } from 'astro:content';
import CategoryLayout from '../../../layouts/CategoryLayout.astro';
import { siteConfig } from '../../../../site.config';
import { categoryGuides } from '../../../data/category-guides';

const INITIAL_COUNT = 12;
const MAX_RENDER = 24; // Only render this many in HTML; rest load via "Load More" button

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category))];

  const allCategorySlugs = [
    ...siteConfig.categories.map(c => c.slug),
    ...categories.map(c => c.toLowerCase().replace(/\s+/g, '-')),
  ];
  const uniqueSlugs = [...new Set(allCategorySlugs)];

  return uniqueSlugs.map(slug => {
    const catPosts = posts
      .filter(p => p.data.category.toLowerCase().replace(/\s+/g, '-') === slug)
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
    const configCat = siteConfig.categories.find(c => c.slug === slug);
    const catName = configCat?.name || slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

    return {
      params: { category: slug },
      props: { categoryName: catName, categorySlug: slug, allPosts: catPosts },
    };
  });
}

const { categoryName, categorySlug, allPosts } = Astro.props;
const guide = categoryGuides[categorySlug];

const schema: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": guide?.title || categoryName,
    "url": `${siteConfig.url}/category/${categorySlug}/`,
    "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": siteConfig.url },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url + "/" },
      { "@type": "ListItem", "position": 2, "name": categoryName, "item": `${siteConfig.url}/category/${categorySlug}/` },
    ],
  },
];

// Add FAQ schema if guide has FAQ
if (guide?.faq?.length) {
  schema.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": guide.faq.map((item: { question: string; answer: string }) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  });
}

const popularPosts = allPosts.slice(0, 5).map((p: any) => ({
  title: p.data.title,
  href: `/${p.id}/`,
  date: (p.data.updatedDate || p.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
}));
---

<CategoryLayout
  title={guide?.title || categoryName}
  description={guide ? guide.intro.slice(0, 155) + '...' : `Browse all ${categoryName} articles — reviews, comparisons, and buying guides.`}
  subtitle={guide?.intro || `In-depth reviews, comparisons, and buying guides for every type of ${categoryName.toLowerCase()} — tested and reviewed by our team.`}
  activeNav={categorySlug}
  schema={schema}
  popularPosts={popularPosts}
  postCount={allPosts.length}
>
  {/* Pillar Guide Content */}
  {guide && (
    <div class="pillar-guide">
      {guide.sections.map((section) => (
        <div class="pillar-section">
          <h2>{section.heading}</h2>
          {section.content.split('\n\n').map((para: string) => (
            <p>{para}</p>
          ))}
          {section.tip && (
            <div class="pillar-tip">
              <span class="pillar-tip-label">Pro Tip</span>
              <p>{section.tip}</p>
            </div>
          )}
          {section.table && (
            <div class="pillar-table-wrap">
              <table class="pillar-table">
                <thead>
                  <tr>{section.table.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {section.table.rows.map((row: string[]) => (
                    <tr>{row.map((cell: string) => <td>{cell}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {section.links && section.links.length > 0 && (
            <div class="pillar-links">
              <strong>Read more:</strong>
              <ul>
                {section.links.map((link) => (
                  <li><a href={link.href}>{link.text}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      ))}

      {/* FAQ Section */}
      {guide.faq && guide.faq.length > 0 && (
        <div class="pillar-faq">
          <h2>Frequently Asked Questions</h2>
          {guide.faq.map((item) => (
            <div class="pillar-faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </div>
          ))}
        </div>
      )}

      <h2 class="pillar-articles-heading">All {categoryName} Articles ({allPosts.length})</h2>
    </div>
  )}

  <div class="article-grid">
    {allPosts.length > 0 ? (
      allPosts.slice(0, MAX_RENDER).map((post: any, i: number) => (
        <article class={`article-card animate-on-scroll${i >= INITIAL_COUNT ? ' hidden-card' : ''}`}>
          {post.data.image && (
            <a href={`/${post.id}/`} class="article-card-img">
              <img src={post.data.image} alt={post.data.imageAlt || post.data.title} width="400" height="200" loading={i < 2 ? 'eager' : 'lazy'} />
              <span class="article-card-badge">{post.data.postType.replace('-', ' ')}</span>
            </a>
          )}
          <div class="article-card-body">
            <h2 class="article-card-title"><a href={`/${post.id}/`}>{post.data.title}</a></h2>
            <p class="article-card-excerpt">{post.data.description}</p>
            <div class="article-card-meta">
              <span>{post.data.author || siteConfig.author.name}</span>
              <span class="article-card-meta-dot"></span>
              <span>{(post.data.updatedDate || post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </div>
          </div>
        </article>
      ))
    ) : (
      <p style="color: var(--text-secondary); padding: 40px 0;">No articles in this category yet.</p>
    )}

    {allPosts.length > INITIAL_COUNT && (
      <div class="load-more-wrap">
        <button class="load-more-btn" id="load-more-btn">
          {allPosts.length > MAX_RENDER ? `Load More (${allPosts.length - MAX_RENDER} more)` : 'Load More Articles'}
        </button>
      </div>
    )}

    {/* Store remaining posts as JSON for client-side lazy rendering */}
    {allPosts.length > MAX_RENDER && (
      <script is:inline define:vars={{ remainingPosts: allPosts.slice(MAX_RENDER).map((p: any) => ({
        id: p.id,
        title: p.data.title,
        description: p.data.description,
        image: p.data.image,
        imageAlt: p.data.imageAlt || p.data.title,
        postType: p.data.postType,
        author: p.data.author || '',
        date: (p.data.updatedDate || p.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
      })), authorName: siteConfig.author.name }}>
        window.__remainingPosts = remainingPosts;
        window.__authorName = authorName;
      </script>
    )}
  </div>
</CategoryLayout>

<script is:inline>
(function() {
  var btn = document.getElementById('load-more-btn');
  if (!btn) return;
  var BATCH = 12;
  var remaining = window.__remainingPosts || [];
  var authorName = window.__authorName || '';
  var idx = 0;
  var grid = document.querySelector('.article-grid');

  function createCard(post) {
    var card = document.createElement('article');
    card.className = 'article-card animate-on-scroll visible';
    card.innerHTML =
      (post.image ? '<a href="/' + post.id + '/" class="article-card-img"><img src="' + post.image + '" alt="' + post.title.replace(/"/g,'&quot;') + '" width="400" height="200" loading="lazy" /><span class="article-card-badge">' + post.postType.replace('-',' ') + '</span></a>' : '') +
      '<div class="article-card-body"><h2 class="article-card-title"><a href="/' + post.id + '/">' + post.title + '</a></h2><p class="article-card-excerpt">' + post.description + '</p><div class="article-card-meta"><span>' + (post.author || authorName) + '</span><span class="article-card-meta-dot"></span><span>' + post.date + '</span></div></div>';
    return card;
  }

  btn.addEventListener('click', function() {
    // First reveal hidden cards already in DOM
    var hidden = document.querySelectorAll('.hidden-card');
    var count = 0;
    for (var i = 0; i < hidden.length && count < BATCH; i++, count++) {
      hidden[i].classList.remove('hidden-card');
    }
    // Then append remaining posts from JSON
    if (hidden.length <= BATCH && remaining.length > 0) {
      var end = Math.min(idx + BATCH - count, remaining.length);
      for (var j = idx; j < end; j++) {
        grid.insertBefore(createCard(remaining[j]), btn.parentElement);
      }
      idx = end;
    }
    // Hide button when all done
    if (document.querySelectorAll('.hidden-card').length === 0 && idx >= remaining.length) {
      btn.style.display = 'none';
    } else {
      var left = document.querySelectorAll('.hidden-card').length + (remaining.length - idx);
      btn.textContent = left > 0 ? 'Load More (' + left + ' more)' : 'Load More Articles';
    }
  });
})();
</script>

<style>
  /* Pillar Guide */
  .pillar-guide {
    margin-bottom: 40px;
  }
  .pillar-section {
    margin-bottom: 32px;
  }
  .pillar-section h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 12px;
  }
  .pillar-section p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .pillar-links {
    background: var(--accent-light, #f0f4ff);
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
    margin-top: 8px;
  }
  .pillar-links strong {
    font-size: 13px;
    color: var(--text);
    display: block;
    margin-bottom: 6px;
  }
  .pillar-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }
  .pillar-links li::before {
    content: '→ ';
    color: var(--accent);
    font-weight: 700;
  }
  .pillar-links a {
    font-size: 14px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }
  .pillar-links a:hover {
    text-decoration: underline;
  }

  /* Pro Tip */
  .pillar-tip {
    background: #f0fdf4;
    border-left: 4px solid #22c55e;
    padding: 14px 18px;
    border-radius: 0 8px 8px 0;
    margin: 16px 0;
  }
  :root[data-theme="dark"] .pillar-tip {
    background: #14532d20;
  }
  .pillar-tip-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #16a34a;
    margin-bottom: 6px;
  }
  .pillar-tip p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Table */
  .pillar-table-wrap {
    overflow-x: auto;
    margin: 16px 0;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .pillar-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    line-height: 1.5;
  }
  .pillar-table th {
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    text-align: left;
    padding: 10px 14px;
    white-space: nowrap;
  }
  .pillar-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .pillar-table tr:last-child td {
    border-bottom: none;
  }
  .pillar-table tr:nth-child(even) {
    background: var(--accent-light, #f8f9fc);
  }

  .pillar-faq {
    margin: 32px 0;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }
  .pillar-faq h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 16px;
  }
  .pillar-faq-item {
    margin-bottom: 20px;
  }
  .pillar-faq-item h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }
  .pillar-faq-item p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }
  .pillar-articles-heading {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text);
    margin: 32px 0 16px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .article-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    display: flex;
    flex-direction: column;
  }
  .article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .article-card-img {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .article-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .article-card:hover .article-card-img img { transform: scale(1.05); }
  .article-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .article-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .article-card-title {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .article-card-title a { color: var(--text); }
  .article-card-title a:hover { color: var(--accent); }
  .article-card-excerpt {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-light);
    flex-wrap: wrap;
  }
  .article-card-meta-dot {
    width: 3px;
    height: 3px;
    background: var(--text-light);
    border-radius: 50%;
  }

  /* Hidden cards & Load More */
  .hidden-card { display: none; }
  .load-more-wrap {
    grid-column: 1 / -1;
    text-align: center;
    margin-top: 30px;
  }
  .load-more-btn {
    display: inline-block;
    padding: 12px 36px;
    border: 2px solid var(--accent);
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    border-radius: var(--radius);
    background: none;
    cursor: pointer;
    transition: all var(--transition);
  }
  .load-more-btn:hover { background: var(--accent); color: #fff; }

  @media (max-width: 768px) {
    .article-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .article-card-img { height: 180px; }
  }
</style>
