---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';

const cardColors = ['accent', 'teal', 'amber'];

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Start Here - ${siteConfig.name}`,
  "description": `New to ${siteConfig.name}? Start here for the best guides, reviews, and resources to find the right products.`,
  "url": `${siteConfig.url}/start-here/`,
  "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": siteConfig.url }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Start Here", "item": `${siteConfig.url}/start-here/` }
  ]
};

/* SVG icons for path cards — one per category (cycles if > 3) */
const pathIcons = [
  /* Drop / filter */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  /* Flame / heater */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6 0-4 5-11 9-14 4 3 9 10 9 14 0 3.31-4.03 6-9 6z"/><path d="M12 22c-1.66 0-3-1.12-3-2.5S10.34 15 12 15s3 3 3 4.5-1.34 2.5-3 2.5z"/></svg>`,
  /* Gear / softener */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
];

/* Guide group labels + color keys */
const guideGroupLabels = ['Top Picks', 'Reviews & Comparisons', 'Learn'];
const guideGroupColors = ['top-picks', 'reviews', 'learn'];

/* Popular guides per group — uses footerPopularLinks + some placeholders */
const popularLinks = siteConfig.footerPopularLinks || [];
---

<BaseLayout
  title="Start Here"
  description={`New to ${siteConfig.name}? Start here for the best guides, reviews, and resources to find the right products.`}
  activeNav="start-here"
  schema={[pageSchema, breadcrumbSchema]}
>

<!-- ============================================================
     1. HERO
     ============================================================ -->
<section class="sh-hero">
  <div class="container">
    <h1 class="sh-hero-title animate-on-scroll">Welcome to {siteConfig.name}</h1>
    <p class="sh-hero-subtitle animate-on-scroll">Your complete guide to raising healthy, happy goats &mdash; with practical advice on diet, health, breeding, housing, and everything in between.</p>
  </div>
</section>

<!-- ============================================================
     2. QUICK INTRO
     ============================================================ -->
<section class="sh-intro">
  <div class="container">
    <div class="sh-intro-inner animate-on-scroll">
      {siteConfig.author.image ? (
        <img class="sh-avatar" src={siteConfig.author.image} alt={siteConfig.author.name} />
      ) : (
        <div class="sh-avatar">{siteConfig.author.initial}</div>
      )}
      <div class="sh-intro-text">
        <p><strong>Hey, I'm {siteConfig.author.name}.</strong> I've been raising goats for over a decade and I started Goats Authority because finding reliable, goat-specific care advice online is harder than it should be. Most sites give generic livestock advice that doesn't account for how different goats are from sheep or cattle.</p>
        <p>We've published 399 articles covering every aspect of goat ownership &mdash; from "can my goat eat this?" to managing breeding programs and treating common health issues. Whether you're bringing home your first pair of kids or managing a herd of 50, the guides below will help.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     3. PICK YOUR PATH
     ============================================================ -->
<section class="sh-paths">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">Pick Your Path</h2>
    <p class="sh-section-subtitle animate-on-scroll">Not sure where to start? Choose the category that fits your needs.</p>
    <div class="sh-paths-grid">
      {siteConfig.categories.map((cat, i) => {
        const color = cardColors[i % cardColors.length];
        return (
          <a href={`/category/${cat.slug}`} class={`sh-path-card sh-path-card--${color} animate-on-scroll`}>
            <div class={`sh-path-icon sh-path-icon--${color}`} set:html={pathIcons[i % pathIcons.length]} />
            <h3>I Need {cat.name}</h3>
            <p>{cat.name === 'Diet' ? 'Complete guides to what goats can and can\'t eat, from fruits and hay to kitchen scraps and toxic plants.' :
               cat.name === 'Health' ? 'Symptoms, treatments, deworming, vaccinations, and when to call the vet.' :
               cat.name === 'Breeding' ? 'Breed selection, mating, genetics, reproduction, pregnancy, kidding, and raising kids from birth.' :
               cat.name === 'Food' ? 'Goat milk, cheese, meat products, and recipes for humans.' :
               cat.name === 'Housing' ? 'Barn design, fencing, shelter, bedding, and pasture management.' :
               cat.name === 'Training' ? 'House training, leash training, behavior correction, breed traits, and temperament.' :
               cat.name === 'Safety' ? 'Predator protection, toxic plants, and escape prevention.' :
               `Everything you need to know about ${cat.name.toLowerCase()} in goat care.`}</p>
            <span class="sh-path-link">Explore {cat.name} &rarr;</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================================================
     4. COMMON QUESTIONS
     ============================================================ -->
<section class="sh-problems">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">Common Goat Questions</h2>
    <p class="sh-section-subtitle animate-on-scroll">Jump straight to the answer you need.</p>
    <div class="sh-problems-grid">
      <a href="/can-goats-eat-apples/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127822;</span>
        <h3>Can My Goat Eat This?</h3>
        <p>163 articles covering every food from apples to zucchini, with safety ratings, portion sizes, and risks.</p>
      </a>
      <a href="/can-alfalfa-pellets-cause-goats-to-bloat/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#129658;</span>
        <h3>My Goat Seems Sick</h3>
        <p>Bloating, lethargy, limping, and other symptoms explained with causes and treatment options.</p>
      </a>
      <a href="/can-a-goat-breed-with-sheep/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#128037;</span>
        <h3>Breeding Questions</h3>
        <p>Cross-breeding compatibility, heat cycles, pregnancy signs, and kid care from day one.</p>
      </a>
      <a href="/can-a-goat-live-in-a-house/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127968;</span>
        <h3>Housing & Space Needs</h3>
        <p>Barn sizes, indoor vs outdoor living, fencing requirements, and house training options.</p>
      </a>
      <a href="/can-a-goat-get-rabies/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#128138;</span>
        <h3>Vaccines & Prevention</h3>
        <p>CDT shots, rabies, deworming schedules, and preventive care to keep your herd healthy.</p>
      </a>
      <a href="/can-a-female-goat-produce-milk-without-being-pregnant/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#129371;</span>
        <h3>Milk & Dairy Questions</h3>
        <p>Milking without pregnancy, milk production, udder health, and dairy goat management.</p>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     5. BROWSE BY TOPIC
     ============================================================ -->
<section class="sh-guides">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">Browse by Topic</h2>
    <p class="sh-section-subtitle animate-on-scroll">Dive into the topics that matter most to goat owners.</p>
    <div class="sh-guides-groups">

      {/* Group 1: Feeding & Nutrition */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--top-picks">Feeding &amp; Nutrition</span>
        <div class="sh-guide-list">
          <a href="/category/what-do-goats-eat" class="sh-guide-item">
            <div class="sh-guide-item-title">Goat Diet Guide</div>
            <div class="sh-guide-item-desc">163 articles covering every food goats can and can't eat, from fruits and vegetables to hay, grains, and common kitchen scraps. Each guide includes safety info, portion sizes, and potential risks.</div>
          </a>
          <a href="/what-kind-of-hay-do-goats-eat/" class="sh-guide-item">
            <div class="sh-guide-item-title">Hay &amp; Forage Basics</div>
            <div class="sh-guide-item-desc">Timothy, alfalfa, orchard grass, and more. Learn which hay types are best for different ages and breeds, how much to feed, and what to avoid.</div>
          </a>
          <a href="/can-goats-eat-chocolate/" class="sh-guide-item">
            <div class="sh-guide-item-title">Toxic Foods to Avoid</div>
            <div class="sh-guide-item-desc">Chocolate, avocado, onions, and other common foods that can make your goat seriously sick. Know the warning signs before it's too late.</div>
          </a>
        </div>
      </div>

      {/* Group 2: Health & Wellness */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--reviews">Health &amp; Wellness</span>
        <div class="sh-guide-list">
          <a href="/category/health" class="sh-guide-item">
            <div class="sh-guide-item-title">Goat Health Hub</div>
            <div class="sh-guide-item-desc">102 articles on symptoms, diseases, medications, and preventive care. From deworming schedules to emergency treatments, find answers to your goat health questions.</div>
          </a>
          <a href="/can-a-cdt-shot-kill-a-goat/" class="sh-guide-item">
            <div class="sh-guide-item-title">Vaccinations &amp; CDT Shots</div>
            <div class="sh-guide-item-desc">Everything you need to know about the CDT vaccine, dosing, timing, side effects, and why it's essential for every goat herd.</div>
          </a>
          <a href="/can-you-deworm-a-pregnant-goat/" class="sh-guide-item">
            <div class="sh-guide-item-title">Deworming &amp; Parasites</div>
            <div class="sh-guide-item-desc">Safe deworming protocols for kids, pregnant does, and adult goats. Includes ivermectin, fenbendazole, and natural alternatives.</div>
          </a>
        </div>
      </div>

      {/* Group 3: Breeding, Housing & More */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--learn">Ownership &amp; Care</span>
        <div class="sh-guide-list">
          <a href="/category/breeding" class="sh-guide-item">
            <div class="sh-guide-item-title">Breeding, Reproduction &amp; Pregnancy</div>
            <div class="sh-guide-item-desc">Breed profiles, crossbreeding compatibility, genetics, heat cycles, mating, gestation, kidding, and raising kids from birth. Plus local zoning guides for keeping goats in your area.</div>
          </a>
          <a href="/category/housing" class="sh-guide-item">
            <div class="sh-guide-item-title">Housing &amp; Shelter</div>
            <div class="sh-guide-item-desc">Barn sizing, fencing solutions, bedding options, pasture management, and cohabitation with other animals like chickens, pigs, and dogs.</div>
          </a>
          <a href="/category/training" class="sh-guide-item">
            <div class="sh-guide-item-title">Training &amp; Behavior</div>
            <div class="sh-guide-item-desc">House training, leash training, managing aggression, and building a bond with your goats. Practical tips for pet goat owners and farmers alike.</div>
          </a>
          <a href="/category/safety" class="sh-guide-item">
            <div class="sh-guide-item-title">Safety &amp; Protection</div>
            <div class="sh-guide-item-desc">Predator prevention, fencing solutions, toxic plant identification, and keeping your goats safe from foxes, raccoons, and other threats.</div>
          </a>
          <a href="/about" class="sh-guide-item">
            <div class="sh-guide-item-title">About Goats Authority</div>
            <div class="sh-guide-item-desc">Meet Jake Holloway and learn why he built this site after a decade of hands-on goat raising experience.</div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
     ============================================================ */
  .sh-hero {
    background: var(--bg-dark);
    padding: 80px 0 70px;
    text-align: center;
  }
  .sh-hero-title {
    font-size: 2.8rem;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.15;
  }
  .sh-hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.65);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ============================================================
     QUICK INTRO
     ============================================================ */
  .sh-intro {
    padding: 60px 0;
  }
  .sh-intro-inner {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    max-width: 820px;
    margin: 0 auto;
  }
  img.sh-avatar {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
  }
  div.sh-avatar {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 800;
    color: #fff;
  }
  .sh-intro-text {
    flex: 1;
  }
  .sh-intro-text p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .sh-intro-text p:last-child { margin-bottom: 0; }
  .sh-intro-text strong { color: var(--text); font-weight: 700; }

  /* ============================================================
     PICK YOUR PATH
     ============================================================ */
  .sh-paths {
    background: var(--bg-alt);
    padding: 60px 0 65px;
  }
  .sh-section-title {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 12px;
  }
  .sh-section-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    text-align: center;
    max-width: 500px;
    margin: 0 auto 40px;
  }
  .sh-paths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .sh-path-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 36px 28px 32px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    text-align: center;
    display: block;
    color: var(--text);
    border-top: 4px solid transparent;
  }
  .sh-path-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    color: var(--text);
  }
  .sh-path-card--accent { border-top-color: var(--accent); }
  .sh-path-card--teal { border-top-color: #2dc0bb; }
  .sh-path-card--amber { border-top-color: #e8a317; }

  .sh-path-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 24px;
  }
  .sh-path-icon--accent { background: var(--accent-light); color: var(--accent); }
  .sh-path-icon--teal { background: rgba(45,192,187,0.12); color: #2dc0bb; }
  .sh-path-icon--amber { background: rgba(232,163,23,0.12); color: #e8a317; }

  :global(html.dark) .sh-path-icon--teal { background: rgba(45,192,187,0.15); }
  :global(html.dark) .sh-path-icon--amber { background: rgba(232,163,23,0.15); }

  .sh-path-card h3 {
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 10px;
  }
  .sh-path-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 18px;
  }
  .sh-path-link {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    transition: color var(--transition);
  }
  .sh-path-card--teal .sh-path-link { color: #2dc0bb; }
  .sh-path-card--amber .sh-path-link { color: #e8a317; }
  .sh-path-card:hover .sh-path-link { text-decoration: underline; }

  /* ============================================================
     COMMON QUESTIONS
     ============================================================ */
  .sh-problems { padding: 65px 0 60px; }
  .sh-problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .sh-problem-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px 24px; transition: box-shadow var(--transition), transform var(--transition); color: var(--text); display: block; }
  .sh-problem-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); color: var(--text); }
  .sh-problem-icon { font-size: 28px; display: block; margin-bottom: 12px; }
  .sh-problem-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
  .sh-problem-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

  /* ============================================================
     MOST POPULAR GUIDES
     ============================================================ */
  .sh-guides {
    padding: 65px 0 60px;
  }
  .sh-guides-groups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 40px;
  }
  .sh-guides-groups > div {
    display: flex;
    flex-direction: column;
  }
  .sh-guide-group-label {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 10px;
    margin-bottom: 0;
    display: inline-block;
  }
  .sh-guide-group-label--top-picks {
    color: var(--accent);
    border-bottom: 3px solid var(--accent);
  }
  .sh-guide-group-label--reviews {
    color: #2dc0bb;
    border-bottom: 3px solid #2dc0bb;
  }
  .sh-guide-group-label--learn {
    color: #e8a317;
    border-bottom: 3px solid #e8a317;
  }
  .sh-guide-list {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .sh-guide-item {
    display: block;
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    transition: background var(--transition);
    color: var(--text);
    flex: 1;
  }
  .sh-guide-item:last-child { border-bottom: none; }
  .sh-guide-item:hover {
    background: var(--accent-light);
    color: var(--text);
  }
  .sh-guide-item-title {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 3px;
  }
  .sh-guide-item-desc {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.5;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .sh-hero { padding: 60px 0 50px; }
    .sh-hero-title { font-size: 2rem; }
    .sh-hero-subtitle { font-size: 1rem; }

    .sh-intro-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .sh-paths-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }

    .sh-problems-grid { grid-template-columns: 1fr; }

    .sh-guides-groups { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .sh-hero-title { font-size: 1.65rem; }
    .sh-hero { padding: 48px 0 40px; }
    .sh-section-title { font-size: 1.5rem; }
  }
</style>
