{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "goatsauthority-blog",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "not_found_handling": "none"
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    { "binding": "SESSION", "id": "1c3125cfd1dd4cd4ba2c4f1ade4ae070" }
  ]
}
